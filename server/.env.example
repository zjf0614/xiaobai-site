# ============================================
# 小白网站 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ============================================

# 服务器配置
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=xiaobai_site

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# AI 配置（可选）
USE_LLM=false
LLM_API_KEY=your_llm_api_key
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-3.5-turbo

# 生产环境配置
NODE_ENV=production